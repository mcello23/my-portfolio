# Cloudflare Pages SPA Redirect Rules
# This file ensures React Router works correctly on Cloudflare Pages
# All routes should be handled by index.html (SPA)

# Never rewrite real asset requests to index.html.
/assets/*    /assets/:splat    200
/css/*       /css/:splat       200
/js/*        /js/:splat        200
/images/*    /images/:splat    200
/favicon/*   /favicon/:splat   200
/robots.txt  /robots.txt       200
/sitemap.xml /sitemap.xml      200

# Redirect all routes to index.html for client-side routing
/*    /index.html   200
