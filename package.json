{
  "name": "webpage-tests",
  "version": "1.0.0",
  "description": "Linting and tests for Marcelo's webpage",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=24.14.1",
    "yarn": ">=4.0.0"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:all": "jest --coverage",
    "test:watch": "jest --watch",
    "test:components": "jest src/",
    "test:k6": "./tests/k6/run-tests.sh",
    "test:puppeteer": "./tests/puppeteer/run-tests.sh",
    "test:reports": "yarn test --json --outputFile=tests/jest/reports/results-latest.json && cd tests/k6 && ./run-tests.sh && cd ../..",
    "generate-test-data": "node scripts/generate-test-data.js",
    "build:cloudflare": "vite build && node scripts/generate-csp-headers.js && mkdir -p tests/jest/reports tests/k6/reports && yarn test --silent --json --outputFile=tests/jest/reports/results-latest.json || echo '{\"success\":false}' > tests/jest/reports/results-latest.json && yarn generate-test-data && mv test-data.js dist/",
    "lint": "eslint . --ext .js,.html",
    "lint:fix": "eslint . --ext .js,.html --fix",
    "lint:css": "stylelint '**/*.css'",
    "lint:css:fix": "stylelint '**/*.css' --fix",
    "format": "prettier --write '**/*.{js,html,css,json}'",
    "format:check": "prettier --check '**/*.{js,html,css,json}'",
    "quality": "yarn lint && yarn lint:css && yarn format:check",
    "quality:fix": "yarn lint:fix && yarn lint:css:fix && yarn format",
    "prepare": "husky && sh .husky/install.sh",
    "postinstall": "husky && sh .husky/install.sh || true",
    "dev": "vite",
    "build": "vite build && node scripts/generate-csp-headers.js",
    "preview": "vite preview",
    "preview:csp": "node scripts/test-csp-server.js"
  },
  "devDependencies": {
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-html": "^8.1.4",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "puppeteer": "^24.40.0",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.8",
    "wrangler": "^4.81.1"
  },
  "lint-staged": {
    "*.{js,jsx,html,json}": "prettier --write --ignore-unknown",
    "*.css": [
      "stylelint --fix",
      "prettier --write --ignore-unknown"
    ],
    "*.{js,html}": "eslint --fix --no-warn-ignored",
    "*.jsx": "eslint --fix --no-warn-ignored"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0"
  },
  "resolutions": {
    "rollup-plugin-inject": "npm:@rollup/plugin-inject@^5.0.5",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15",
    "tar": "npm:^7.5.7"
  }
}
